<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
     width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}"
     shape-rendering="crispEdges">
  <defs>
    <!-- CRT scanline pattern -->
    <pattern id="scanlines" x="0" y="0" width="1" height="4" patternUnits="userSpaceOnUse">
      <rect x="0" y="0" width="1" height="2" fill="transparent"/>
      <rect x="0" y="2" width="1" height="2" fill="rgba(0,0,0,0.15)"/>
    </pattern>

    <!-- Accent glow filter -->
    <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>

    <!-- Soft glow for text -->
    <filter id="textGlow" x="-10%" y="-20%" width="120%" height="140%">
      <feGaussianBlur stdDeviation="2" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>

    <!-- Marquee animation for tagline -->
    {% if tagline_marquee.enabled %}
    <style>
      @keyframes marquee-tagline {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .marquee-tagline-inner {
        animation: marquee-tagline {{ tagline_marquee.duration }}s linear infinite;
        white-space: nowrap;
        display: inline-block;
      }
    </style>
    {% endif %}

    <!-- Marquee animation for about -->
    {% if about_marquee.enabled %}
    <style>
      @keyframes marquee-about {
        0%   { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .marquee-about-inner {
        animation: marquee-about {{ about_marquee.duration }}s linear infinite;
        white-space: nowrap;
        display: inline-block;
      }
    </style>
    {% endif %}

    <!-- Pulse animation for status dot -->
    <style>
      @keyframes pulse-dot {
        0%, 100% {
          opacity: 1;
          filter: drop-shadow(0 0 4px #{{ accent_color }}) drop-shadow(0 0 8px #{{ accent_color }});
        }
        50% {
          opacity: 0.4;
          filter: drop-shadow(0 0 8px #{{ accent_color }}) drop-shadow(0 0 16px #{{ accent_color }});
        }
      }
      .status-dot {
        animation: pulse-dot 2s ease-in-out infinite;
      }

      <!-- Blinking cursor -->
      @keyframes blink-cursor {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }
      .cursor {
        animation: blink-cursor 1s step-end infinite;
      }
    </style>

    <!-- Clip path for marquee container -->
    <clipPath id="tagline-clip">
      <rect x="0" y="0" width="{{ width - padding_left - padding_right - 20 }}" height="20"/>
    </clipPath>
    <clipPath id="about-clip">
      <rect x="0" y="0" width="{{ width - padding_left - padding_right - 20 }}" height="18"/>
    </clipPath>
  </defs>

  <!-- Background -->
  <rect width="{{ width }}" height="{{ height }}" rx="{{ border_radius }}" fill="#{{ background_color }}"/>

  <!-- CRT Scanlines overlay -->
  <rect width="{{ width }}" height="{{ height }}" rx="{{ border_radius }}"
        fill="url(#scanlines)" opacity="0.6"/>

  <!-- Border -->
  <rect width="{{ width }}" height="{{ height }}" rx="{{ border_radius }}"
        fill="none" stroke="#{{ border_color }}" stroke-width="{{ border_width }}"/>

  <!-- ===== HEADER: Status dot + Clock ===== -->
  <g transform="translate({{ padding_left + border_width }}, {{ dot_top_offset }})">
    <!-- Green status dot with pulse -->
    <circle cx="{{ dot_size / 2 }}" cy="{{ dot_size / 2 }}"
            r="{{ dot_size / 2 }}" fill="#{{ accent_color }}" class="status-dot"/>
    <!-- Clock text -->
    <text x="{{ dot_size + dot_margin_right + clock_margin_left }}"
          y="{{ dot_size / 2 + clock_font_size * 0.35 }}"
          font-family="monospace" font-size="{{ clock_font_size }}"
          fill="#{{ accent_color }}" opacity="0.8"
          style="text-shadow: 0 0 8px #{{ accent_color }};">
      {{ current_time }}
    </text>
  </g>

  <!-- ===== HERO: Name + Tagline ===== -->
  {% set hero_x = padding_left + border_width %}
  {% set hero_y = dot_top_offset + 18 %}

  <!-- Name line -->
  <text x="{{ hero_x }}" y="{{ hero_y + name_font_size }}"
        font-family="monospace" font-size="{{ name_font_size }}"
        font-weight="700" fill="#{{ text_color }}"
        letter-spacing="-0.02em">
    Nguyen Trong Phuc
  </text>

  <!-- PX03 accent -->
  <text x="{{ hero_x + 240 }}" y="{{ hero_y + name_font_size }}"
        font-family="monospace" font-size="{{ name_font_size }}"
        font-weight="700" fill="#{{ red_color }}"
        style="text-shadow: 0 0 12px rgba(229,9,20,0.5);">
    {{ mono_accent }}
  </text>

  <!-- Tagline with marquee -->
  {% set tagline_y = hero_y + name_font_size + tagline_margin_top + tagline_font_size + 2 %}
  {% if tagline_marquee.enabled %}
  <g transform="translate({{ hero_x }}, {{ tagline_y }})" clip-path="url(#tagline-clip)">
    <text font-family="monospace" font-size="{{ tagline_font_size }}"
          fill="#{{ secondary_color }}" opacity="0.85">
      <tspan class="marquee-tagline-inner">
        {{ tagline }}&nbsp;&nbsp;&nbsp;&nbsp;{{ tagline }}&nbsp;&nbsp;&nbsp;&nbsp;
      </tspan>
    </text>
  </g>
  {% else %}
  <text x="{{ hero_x }}" y="{{ tagline_y }}"
        font-family="monospace" font-size="{{ tagline_font_size }}"
        fill="#{{ secondary_color }}" opacity="0.85">
    {{ tagline }}
  </text>
  {% endif %}

  <!-- Blinking cursor after tagline -->
  <text x="{{ hero_x + tagline|length * tagline_font_size * 0.6 + 4 }}"
        y="{{ tagline_y }}"
        font-family="monospace" font-size="{{ tagline_font_size }}"
        fill="#{{ accent_color }}" class="cursor">_</text>

  <!-- ===== ABOUT SECTION ===== -->
  {% set about_y = tagline_y + tagline_font_size + about_margin_top + 4 %}

  <!-- Prompt -->
  <text x="{{ hero_x }}" y="{{ about_y }}"
        font-family="monospace" font-size="{{ about_font_size }}"
        font-weight="600" fill="#{{ accent_color }}"
        style="text-shadow: 0 0 8px #{{ accent_color }};">
    $
  </text>

  <!-- About text with marquee -->
  {% if about_marquee.enabled %}
  <g transform="translate({{ hero_x + 14 }}, {{ about_y }})" clip-path="url(#about-clip)">
    <text font-family="monospace" font-size="{{ about_font_size }}"
          fill="#{{ secondary_color }}">
      <tspan class="marquee-about-inner">
        {{ about }}&nbsp;&nbsp;&nbsp;&nbsp;{{ about }}&nbsp;&nbsp;&nbsp;&nbsp;
      </tspan>
    </text>
  </g>
  {% else %}
  <text x="{{ hero_x + 14 }}" y="{{ about_y }}"
        font-family="monospace" font-size="{{ about_font_size }}"
        fill="#{{ secondary_color }}">
    {{ about }}
  </text>
  {% endif %}

  <!-- ===== LINKS SECTION ===== -->
  {% set links_y = about_y + about_font_size + links_margin_top %}

  <!-- Separator line -->
  <line x1="{{ hero_x }}" y1="{{ links_y - 4 }}"
        x2="{{ width - padding_right - border_width }}" y2="{{ links_y - 4 }}"
        stroke="#{{ border_color }}" stroke-width="1"/>

  <!-- GitHub link -->
  <g transform="translate({{ hero_x }}, {{ links_y }})">
    <!-- GitHub icon (simplified SVG path) -->
    <path d="M 0,3 C 0,1 2,0 4,0 C 6,0 8,1 8,3 C 8,5 7,6 6,7 L 6,10 L 4,8 L 2,10 L 2,7 C 1,6 0,5 0,3 Z M 2,3.5 C 2,4.3 2.7,5 3.5,5 C 4.3,5 5,4.3 5,3.5 C 5,2.7 4.3,2 3.5,2 C 2.7,2 2,2.7 2,3.5 Z"
          fill="#{{ text_color }}" transform="scale(1.4) translate(0,0)"/>
    <text x="18" y="{{ link_height / 2 + link_font_size * 0.35 }}"
          font-family="monospace" font-size="{{ link_font_size }}"
          font-weight="600" fill="#{{ text_color }}">GitHub</text>
    <text x="75" y="{{ link_height / 2 + link_font_size * 0.35 }}"
          font-family="monospace" font-size="{{ link_font_size }}"
          fill="#{{ secondary_color }}">{{ github_link }}</text>
  </g>

  <!-- Email link -->
  {% set email_y = links_y + link_height + link_gap %}
  <g transform="translate({{ hero_x }}, {{ email_y }})">
    <!-- Email icon (envelope) -->
    <rect x="0" y="2" width="14" height="10" rx="1.5"
          fill="none" stroke="#{{ text_color }}" stroke-width="1.5"/>
    <path d="M 0,3 L 7,7.5 L 14,3" fill="none" stroke="#{{ text_color }}" stroke-width="1.5"/>
    <text x="18" y="{{ link_height / 2 + link_font_size * 0.35 }}"
          font-family="monospace" font-size="{{ link_font_size }}"
          font-weight="600" fill="#{{ text_color }}">Email</text>
    <text x="65" y="{{ link_height / 2 + link_font_size * 0.35 }}"
          font-family="monospace" font-size="{{ link_font_size }}"
          fill="#{{ secondary_color }}">{{ email_link }}</text>
  </g>

  <!-- Bottom glow line (accent) -->
  <rect x="{{ border_width }}" y="{{ height - 3 }}"
        width="{{ width - border_width * 2 }}" height="1.5"
        fill="#{{ accent_color }}" opacity="0.3"
        rx="{{ border_radius }}"/>

  <!-- Link to profile (invisible click target covers the whole card) -->
  <a xlink:href="{{ profile_url }}" target="_blank" rel="noopener noreferrer">
    <rect width="{{ width }}" height="{{ height }}"
          fill="transparent" rx="{{ border_radius }}"/>
  </a>
</svg>
